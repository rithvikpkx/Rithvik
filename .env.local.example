# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# RAG: chat completion model (free-tier-friendly)
DEEPSEEK_API_KEY=

# RAG: embeddings (text-embedding-3-small) and image captioning (gpt-4o-mini)
OPENAI_API_KEY=

# Email allowed to receive admin OTPs. Client-side check on top of Supabase's
# shouldCreateUser=false guard. Public — exposed to the browser bundle.
NEXT_PUBLIC_ADMIN_EMAIL=
